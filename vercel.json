{
  "rewrites": [
    {
      "source": "/motopecas/:path*",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        }
      ]
    }
  ],
  "functions": {
    "api/checkout/asaas.js": {
      "maxDuration": 60
    },
    "api/**/*.js": {
      "maxDuration": 15
    }
  }
}
